{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/format.js"],
            "timeout": 30,
            "statusMessage": "Linting and formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/stop-check.js"],
            "timeout": 120,
            "statusMessage": "Running type-check and tests..."
          }
        ]
      }
    ]
  }
}
