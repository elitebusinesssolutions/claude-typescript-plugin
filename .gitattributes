# Auto-detect text files and normalize line endings to LF in the repo.
# Developers on Windows will check out CRLF; Mac/Linux will check out LF.
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.env.example text eol=lf
*.sh text eol=lf

# Lock files — treat as text but do not diff
package-lock.json text eol=lf -diff

# Binary files — do not normalize or diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
